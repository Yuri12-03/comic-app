<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>返却手続き | Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
        <div class="header-actions">
          <a
            href="/logout"
            class="header-logout"
            onclick="return confirm('ログアウトしますか？');"
            >ログアウト</a
          >
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2>返却手続き</h2>
        <p>
          <strong><%= lending.comic_name %></strong> 第<%= lending.volume %>巻
          を返却します。
        </p>
        <p>貸し手: <%= lending.lender_name %></p>
        <p>
          返却予定日: <%= new Date(lending.due).toLocaleDateString('ja-JP') %>
        </p>

        <form
          action="/return/<%= lending.id %>"
          method="post"
          class="submit-once-form"
        >
          <input type="submit" value="返却する" class="submit-once-button" />
        </form>
      </div>

      <a href="/borrowed">借りている本一覧へ戻る</a>
    </div>

    <footer>
      <p>&copy; 2023 Mngr. All rights reserved.</p>
    </footer>
    <script>
      document.querySelectorAll(".submit-once-form").forEach(function (form) {
        form.addEventListener("submit", function () {
          const button = form.querySelector(".submit-once-button");
          if (button) {
            button.disabled = true;
            button.value = "処理中...";
          }
        });
      });
    </script>
  </body>
</html>
