<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <div class="sign">
      <div class="container">
        <h1><a href="/home">Mngr</a></h1>
        <div class="panel">
          <h2>ログイン</h2>
          <form action="/login" method="post" class="submit-once-form">
            <p>メールアドレス</p>
            <input type="text" name="email" />
            <p>パスワード</p>
            <input type="password" name="password" />
            <input type="submit" value="ログイン" class="submit-once-button" />
          </form>
          <a href="/signup">新規登録はこちら</a>
        </div>
      </div>
    </div>
    <script>
      document.querySelectorAll(".submit-once-form").forEach(function (form) {
        form.addEventListener("submit", function () {
          const button = form.querySelector(".submit-once-button");
          if (button) {
            button.disabled = true;
            button.value = "処理中...";
          }
        });
      });
    </script>
  </body>
</html>
