<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>Mngr</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <header>
            <div class="header-inner">
                <div class="header-left">
                    <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
                    <h1><a href="/home">Mngr</a></h1>
                </div>
                <div class="header-actions">
                    <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
                    <p class="header-greeting">こんにちは、<%= username %>さん</p>
                </div>
            </div>
        </header>
        <div class="container">
            <div class="panel">
                <h2>グループ一覧</h2>
                <p>作成したグループを表示します。</p>
                <!-- Group list would be displayed here -->
                <ul class="chat-list">
                    <% groups.forEach((group) => { %>
                        <li>
                            <a href="/groups/<%= group.id %>">
                                <%= group.group_name %>
                            </a>
                        </li>
                    <% }); %>
                </ul>
            </div>
            <a href="/home">ホームへ戻る</a>
        </div>
        <footer>
            <p>&copy; 2026 Mngr. All rights reserved.</p>
        </footer>
    </body>
</html>