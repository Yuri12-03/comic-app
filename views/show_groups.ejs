<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>Comic-app</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <header>
            <h1><a href="/home">Comic-app</a></h1>
            <a href="/logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
            <p>こんにちは、<%= username %>さん</p>
        </header>
        <div class="container">
            <div class="panel">
                <h2>グループ一覧</h2>
                <p>作成したグループを表示します。</p>
                <!-- Group list would be displayed here -->
                <ul>
                    <% groups.forEach((group) => { %>
                        <li><%= group.group_name %></li>
                    <% }); %>
                </ul>
            </div>
            <a href="/home">ホームへ戻る</a>
        </div>
        <footer>
            <p>&copy; 2023 Comic-app. All rights reserved.</p>
        </footer>
    </body>
</html>