<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>Mngr</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <header>
            <div class="header-inner">
                <div class="header-left">
                    <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
                    <h1><a href="/home">Mngr</a></h1>
                </div>
                <div class="header-actions">
                    <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
                    <p class="header-greeting">こんにちは、<%= username %>さん</p>
                </div>
            </div>
        </header>
        <div class="container">
            <div class="panel">
                <h2>漫画を追加</h2>
                <form action="/add" method="post" class="submit-once-form">
                    <input type="hidden" name="comic_id" value="<%= comicId || '' %>" />

                    <div class="form-section">
                        <h3>1. 漫画名</h3>
                        <label for="comic_name">漫画名:</label>
                        <input type="text" id="comic_name" name="comic_name" value="<%= comicName || '' %>" required />
                    </div>

                    <div class="form-section">
                        <h3>2. 巻数</h3>
                        <label for="volume">巻数（単体）:</label>
                        <input type="number" id="volume" name="volume" min="1" placeholder="例: 1" />
                    </div>

                    <div class="form-section">
                        <h3>3. 巻数範囲</h3>
                        <label for="volume_start">開始:</label>
                        <input type="number" id="volume_start" name="volume_start" min="1" placeholder="例: 1" />

                        <label for="volume_end">終了:</label>
                        <input type="number" id="volume_end" name="volume_end" min="1" placeholder="例: 5" />
                    </div>

                    <div class="form-section">
                        <h3>4. 追加先グループ</h3>
                        <label for="group_id">追加先グループ:</label>
                        <select id="group_id" name="group_id" required>
                            <% groups.forEach(function(group) { %>
                                <option value="<%= group.id %>" <%= String(selectedGroupId || '') === String(group.id) ? 'selected' : '' %>>
                                    <%= group.group_name %>
                                </option>
                            <% }); %>
                        </select>
                    </div>

                    <br><br>
                    <input type="submit" value="追加" class="submit-once-button" />
                </form>
                <% if (error) { %>
                    <p class="error"><%= error %></p>
                <% } %>
            </div>
            <a href="/list">漫画一覧へ</a>
        </div>
        <footer>
            <p>&copy; 2026 Mngr. All rights reserved.</p>
        </footer>
        <script>
            document.querySelectorAll('.submit-once-form').forEach(function (form) {
                form.addEventListener('submit', function () {
                    const button = form.querySelector('.submit-once-button');
                    if (button) {
                        button.disabled = true;
                        button.value = '処理中...';
                    }
                });
            });
        </script>
    </body>
</html>