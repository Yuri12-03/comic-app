<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8" />
        <title>Mngr</title>
        <link rel="stylesheet" href="/css/style.css" />
    </head>
    <body>
        <header>
            <div class="header-inner">
                <div class="header-left">
                    <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
                    <h1><a href="/home">Mngr</a></h1>
                </div>
                <div class="header-actions">
                    <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
                    <p class="header-greeting">こんにちは、<%= username %>さん</p>
                </div>
            </div>
        </header>
        <div class="container">
        <div class="panel">
            <h2>グループ作成</h2>
            <form action="/create_group" method="post" class="submit-once-form">
            <label for="group_name">グループ名:</label>
            <input type="text" id="group_name" name="group_name" required />
             <h3>招待するメンバー</h3>

    <div id="email-list">
        <div class="email-item">
            <input
                type="email"
                name="emails"
                placeholder="メールアドレス"
                required
            >
        </div>
    </div>

    <button type="button" id="add-email">＋ メールアドレスを追加</button>

    <br><br>
            <input type="submit" value="作成" class="submit-once-button" />
            </form>
            <% if (error) { %>
            <p class="error"><%= error %></p>
            <% } %>
        </div>
        <a href="/home">ホームへ戻る</a>
        </div>
        <footer>
        <p>&copy; 2026 Mngr. All rights reserved.</p>
        </footer>
        <script>
document.querySelectorAll('.submit-once-form').forEach(function (form) {
    form.addEventListener('submit', function () {
        const button = form.querySelector('.submit-once-button');
        if (button) {
            button.disabled = true;
            button.value = '処理中...';
        }
    });
});

document.getElementById("add-email").addEventListener("click", () => {
    const div = document.createElement("div");
    div.className = "email-item";

    div.innerHTML = `
        <input
            type="email"
            name="emails"
            placeholder="メールアドレス"
            required
        >
        <button type="button" class="remove-email">削除</button>
    `;

    document.getElementById("email-list").appendChild(div);
});

document.addEventListener("click", (e) => {
    if (e.target.classList.contains("remove-email")) {
        e.target.parentElement.remove();
    }
});
</script>
    </body>
</html>