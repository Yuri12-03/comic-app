<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
      </div>
    </header>
    <div class="container">
      <div class="panel">
        <form action="/list" method="get">
          <label for="group">グループを選択:</label>

          <select id="group" name="group_id">
            <option value="">すべてのグループ</option>
            <% groups.forEach(function(group) { %>
              <option
                value="<%= group.id %>"
                <%= selectedGroupId == group.id ? "selected" : "" %>>
                <%= group.group_name %>
              </option>
            <% }); %>
          </select>

          <input
            type="text"
            name="search"
            value="<%= search %>"
            placeholder="漫画を検索"
          >

          <input type="submit" value="検索">
        </form>
        <a href="/add" class="btn-add add-button">漫画を追加</a>
        <h2>漫画一覧</h2>

        <div class="comic-list">
          <% comics.forEach(comic => { %>
            <div class="comic-card">
              <a href="/comics/<%= comic.id %>" class="comic-link">
                <img src="<%= comic.image_url %>" alt="<%= comic.comic_name %>" class="comic-cover" />
                <h3><%= comic.comic_name %></h3>
              </a>
            </div>
          <% }) %>
        </div>

      </div>
      <a href="/home">ホームへ戻る</a>
      <footer>
        <p>&copy; 2026 Mngr. All rights reserved.</p>
      </footer>
    </div>
    <script>
      const selectAllCheckbox = document.getElementById("select-all-comics");
      const comicCheckboxes = Array.from(document.querySelectorAll(".comic-select-checkbox"));

      if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener("change", function () {
          comicCheckboxes.forEach(function (checkbox) {
            checkbox.checked = selectAllCheckbox.checked;
          });
        });

        comicCheckboxes.forEach(function (checkbox) {
          checkbox.addEventListener("change", function () {
            const allChecked = comicCheckboxes.length > 0 && comicCheckboxes.every(function (item) {
              return item.checked;
            });
            selectAllCheckbox.checked = allChecked;
          });
        });
      }
    </script>
  </body>
</html>