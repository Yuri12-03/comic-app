<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Comic-app</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
        <h1><a href="/home">Comic-app</a></h1>
    </header>
    <div class="container">
      <div class="panel">
        <form action="/list" method="get">
  <label for="group">グループを選択:</label>

  <select id="group" name="group_id">
    <option value="">すべてのグループ</option>
    <% groups.forEach(function(group) { %>
      <option
        value="<%= group.id %>"
        <%= selectedGroupId == group.id ? "selected" : "" %>>
        <%= group.group_name %>
      </option>
    <% }); %>
  </select>

  <input
    type="text"
    name="search"
    value="<%= search %>"
    placeholder="漫画を検索"
  >

  <input type="submit" value="検索">
</form>
        <a href="/add">漫画を追加 </a>
        <h2>漫画一覧</h2>
        <ul>
          <% comics.forEach(comic => { %>
  <div class="comic-card">
    <img src="<%= comic.image_url %>" alt="<%= comic.comic_name %>" class="comic-cover" />
    <h3><%= comic.comic_name %></h3>
  </div>
<% }) %>
        </ul>
      </div>
      <a href="/home">ホームへ戻る</a>
      <footer>
        <p>&copy; 2023 Comic-app. All rights reserved.</p>
      </footer>
    </div>
  </body>
</html>