<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>貸し出し | Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2>貸し出し登録</h2>
        <p><strong><%= owning.comic_name %></strong> 第<%= owning.volume %>巻 を貸し出します。</p>

        <% if (error) { %>
          <p class="error"><%= error %></p>
        <% } %>

        <form action="/lend/<%= owning.id %>" method="post" class="submit-once-form">
          <input type="hidden" name="comic_id" value="<%= owning.comic_id %>" />

          <label for="borrower_email">借りる相手のメールアドレス:</label>
          <input type="email" id="borrower_email" name="borrower_email" required />

          <label for="due_days">何日後に返すか:</label>
          <input type="number" id="due_days" name="due_days" min="1" value="7" required />

          <br /><br />
          <input type="submit" value="貸し出し登録" class="submit-once-button" />
        </form>
      </div>

      <a href="/comics/<%= owning.comic_id %>">漫画詳細へ戻る</a>
    </div>

    <footer>
      <p>&copy; 2026 Mngr. All rights reserved.</p>
    </footer>
    <script>
      document.querySelectorAll('.submit-once-form').forEach(function (form) {
        form.addEventListener('submit', function () {
          const button = form.querySelector('.submit-once-button');
          if (button) {
            button.disabled = true;
            button.value = '処理中...';
          }
        });
      });
    </script>
  </body>
</html>
