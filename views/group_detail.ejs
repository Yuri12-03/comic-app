<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title><%= group.group_name %> | Comic-app</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Comic-app</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2><%= group.group_name %></h2>

        <% if (error) { %>
          <p class="error"><%= error %></p>
        <% } %>
        <% if (success) { %>
          <p class="success"><%= success %></p>
        <% } %>

        <h3>メンバー追加</h3>
        <form action="/groups/<%= group.id %>/add_member" method="post" class="group-form submit-once-form">
          <input type="email" name="email" placeholder="メールアドレス" required />
          <button type="submit" class="submit-once-button">追加</button>
        </form>

        <h3>メンバー一覧</h3>
        <ul class="member-list">
          <% members.forEach((member) => { %>
            <li class="member-item">
              <span><%= member.username %>（<%= member.email %>）</span>
              <% if (isHost && member.id !== group.owner_id) { %>
                <form action="/groups/<%= group.id %>/remove_member/<%= member.id %>" method="post" class="inline-form submit-once-form">
                  <button type="submit" class="btn-delete submit-once-button">削除</button>
                </form>
              <% } %>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="navigation-links">
        <a href="/show_groups">グループ一覧へ戻る</a>
      </div>
    </div>

    <footer>
      <p>&copy; 2023 Comic-app. All rights reserved.</p>
    </footer>
    <script>
      document.querySelectorAll('.submit-once-form').forEach(function (form) {
        form.addEventListener('submit', function () {
          const button = form.querySelector('.submit-once-button');
          if (button) {
            button.disabled = true;
            button.textContent = '処理中...';
          }
        });
      });
    </script>
  </body>
</html>
