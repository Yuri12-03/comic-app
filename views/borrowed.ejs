<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>借りている本一覧 | Comic-app</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Comic-app</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2>借りている本一覧</h2>

        <% if (borrowed && borrowed.length > 0) { %>
          <div class="borrowed-list">
            <% borrowed.forEach(function(item) { %>
              <%
                const dueDate = new Date(item.due);
                const now = new Date();
                const daysLeft = Math.ceil((dueDate - now) / (1000 * 60 * 60 * 24));
                const deadlineClass = daysLeft <= 1
                  ? 'deadline-card deadline-card--danger'
                  : (daysLeft <= 3 ? 'deadline-card deadline-card--warning' : '');
              %>
              <div class="borrowed-card <%= deadlineClass %>">
                <a href="/return/<%= item.id %>">
                  <% if (item.image_url && item.image_url.trim() !== '') { %>
                    <img src="<%= item.image_url %>" alt="<%= item.comic_name %>" />
                  <% } else { %>
                    <img src="/images/no-image.png" alt="<%= item.comic_name %>" />
                  <% } %>
                </a>
                <div class="borrowed-info">
                  <h3><%= item.comic_name %> <%= item.volume %>巻</h3>
                  <p><strong>貸し手:</strong> <%= item.lender_name %></p>
                  <p><strong>借りた日:</strong> <%= new Date(item.borrowed_at).toLocaleDateString('ja-JP') %></p>
                  <p><strong>返却予定日:</strong> <%= new Date(item.due).toLocaleDateString('ja-JP') %></p>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p>現在借りている本はありません。</p>
        <% } %>
      </div>

      <a href="/home">ホームへ戻る</a>
    </div>

    <footer>
      <p>&copy; 2023 Comic-app. All rights reserved.</p>
    </footer>
  </body>
</html>
