<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= groupName %> | Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <div class="chat-shell">
          <div class="chat-header">
            <h2><%= groupName %></h2>
            <a href="/chat_list" class="btn-add">グループ一覧へ</a>
          </div>

          <div id="chat-messages">
            <% messages.forEach(message => { %>
              <div class="chat-message <%= message.sender_id === currentUserId ? 'own-message' : 'other-message' %>">
                <strong><%= message.username %>:</strong>
                <span><%= message.message %></span>
              </div>
            <% }) %>
          </div>

          <form id="chat-form" class="chat-form submit-once-form" action="/chat/<%= groupId %>" method="post">
            <input type="text" name="message" placeholder="メッセージを入力" required />
            <button type="submit" class="submit-once-button">送信</button>
          </form>
        </div>
      </div>

      <div class="navigation-links">
        <a href="/home">ホームへ戻る</a>
      </div>
    </div>

    <footer>
      <p>&copy; 2023 Mngr. All rights reserved.</p>
    </footer>
    <script>
      document.querySelectorAll('.submit-once-form').forEach(function (form) {
        form.addEventListener('submit', function () {
          const button = form.querySelector('.submit-once-button');
          if (button) {
            button.disabled = true;
            button.textContent = '送信中...';
          }
        });
      });
    </script>
  </body>
</html>