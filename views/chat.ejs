<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Comic-app</title>
</head>
<body>
    <header>
        <h1><a href="/home">Comic-app</a></h1>
        <a href="/logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
        <p>こんにちは、<%= username %>さん</p>
    </header>
<body>
    <h2><%= groupName %></h2>
    <div id="chat-messages">
        <% messages.forEach(message => { %>
            <p><strong><%= message.username %>:</strong> <%= message.message %></p>
        <% }) %>
    </div>
    <form id="chat-form" action="/chat/<%= groupId %>" method="post">
        <input type="text" name="message" placeholder="メッセージを入力" required />
        <button type="submit">送信</button>
    </form>
</body>