<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>貸している本一覧 | Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2>貸している本一覧</h2>

        <% if (lent && lent.length > 0) { %>
          <div class="lent-list">
            <% lent.forEach((item) => { %>
              <%
                const dueDate = new Date(item.due);
                const now = new Date();
                const daysLeft = Math.ceil((dueDate - now) / (1000 * 60 * 60 * 24));
                const deadlineClass = daysLeft <= 1
                  ? 'deadline-card deadline-card--danger'
                  : (daysLeft <= 3 ? 'deadline-card deadline-card--warning' : '');
              %>
              <div class="lent-card <%= deadlineClass %>">
                <img src="<%= item.image_url || '/images/no-image.png' %>" alt="<%= item.comic_name %>" />
                <div class="lent-info">
                  <h3><%= item.comic_name %> <%= item.volume %>巻</h3>
                  <p><strong>借り手:</strong> <%= item.borrower_name %></p>
                  <p><strong>返却期限:</strong> <%= new Date(item.due).toLocaleDateString('ja-JP') %></p>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <p>現在貸している本はありません。</p>
        <% } %>
      </div>

      <div class="navigation-links">
        <a href="/home">ホームへ戻る</a>
      </div>
    </div>

    <footer>
      <p>&copy; 2023 Mngr. All rights reserved.</p>
    </footer>
  </body>
</html>
