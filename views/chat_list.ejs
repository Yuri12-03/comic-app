<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>Mngr</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <img src="/images/kame.jpg" alt="ロゴ" class="header-logo" />
          <h1><a href="/home">Mngr</a></h1>
        </div>
        <div class="header-actions">
          <a href="/logout" class="header-logout" onclick="return confirm('ログアウトしますか？');">ログアウト</a>
          <p class="header-greeting">こんにちは、<%= username %>さん</p>
        </div>
      </div>
    </header>

    <div class="container">
      <div class="panel">
        <h2>グループ一覧</h2>
        <ul class="chat-list">
          <% groups.forEach(group => { %>
            <li>
              <a href="/chat/<%= group.id %>">
                <%= group.group_name %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>

      <div class="navigation-links">
        <a href="/home">ホームへ戻る</a>
      </div>
    </div>

    <footer>
      <p>&copy; 2023 Mngr. All rights reserved.</p>
    </footer>
  </body>
</html>